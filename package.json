{
  "name": "agendario",
  "version": "0.0.1",
  "private": true,
  "description": "Agendario — workspace médico+financeiro (monorepo)",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @agendario/web dev",
    "dev:bot": "pnpm --filter @agendario/bot dev",
    "dev:inngest": "pnpm dlx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @agendario/db generate",
    "db:migrate": "pnpm --filter @agendario/db migrate",
    "db:studio": "pnpm --filter @agendario/db studio",
    "db:seed:categories": "pnpm --filter @agendario/db seed:categories"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
